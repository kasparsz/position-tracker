{
  "name": "@kasparsz/position-tracker",
  "version": "1.0.3",
  "type": "module",
  "main": "./dist/position-tracker.mjs",
  "module": "./dist/position-tracker.mjs",
  "unpkg": "./dist/position-tracker.mjs",
  "types": "./dist/position-tracker.d.ts",
  "exports": {
    ".": {
      "types": "./dist/position-tracker.d.ts",
      "default": "./dist/position-tracker.mjs"
    },
    "./vue": {
      "types": "./dist/position-tracker-vue.d.ts",
      "default": "./dist/position-tracker-vue.mjs"
    },
    "./dist/*": "./dist/*"
  },

  "author": "Kaspars Zuks",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "playground",
    "playground/*"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "concurrently \"npm run dev:build\" \"npm run dev:playground\"",
    "dev:build": "tsdown --watch",
    "dev:playground": "cd playground && npm run dev",
    "prepublish": "npm run build"
  },
  "devDependencies": {
    "tsdown": "^0.22.1",
    "typescript": "~5.9.3",
    "concurrently": "^10.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kasparsz/position-tracker.git"
  },
  "bugs": {
    "url": "https://github.com/kasparsz/position-tracker/issues"
  },
  "peerDependencies": {
    "alien-signals": ">=3.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "alien-signals": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "volta": {
    "node": "24.12.0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
