---
interface Props {
    title: string
}

const { title } = Astro.props
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body>
        <nav>
            <a href="/signal">Signal</a>
            <a href="/vue">Vue</a>
        </nav>
        <slot />
    </body>
</html>

<style is:global>
    :root {
        font-family: Helvetica, Arial, "Lucida Grande", sans-serif;
        line-height: 1.5;
        font-weight: 400;
  
        font-synthesis: none;
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }
    html {
        font-size: 62.5%;
    }
    body {
        font-size: 1.2rem;
    }
    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }
</style>

<style>
    nav {
        position: fixed;
        z-index: 100;
        bottom: 2px;
        left: 2px;
        right: 2px;
        align-items: center;
        display: flex;
        gap: 2px;
        z-index: 1;

        display: flex;
        justify-content: center;
    }

    a {
        min-width: 60px;
        height: 3rem;
        display: flex;
        justify-content: center;
        align-items: center;
        color: #fff;
        background-color: #000;
        border-radius: 4px;
        transition: all 0.2s ease-in-out;
        padding: 0 1rem;
        
        font-size: 1.4rem;
        text-align: center;
        text-decoration: none;
        text-box: trim-both cap alphabetic;
    }
</style>